{
  "name": "@monou/agent-sdk",
  "version": "0.1.0",
  "description": "High-level agent SDK: createAgent, run loop with pluggable LLM",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npx tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@monou/agent-core": "^0.1.0",
    "@monou/shared": "^0.1.0",
    "@monou/skills": "^0.1.0"
  },
  "keywords": [
    "monou",
    "agent",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "@monou/llm-provider": "^0.1.0",
    "dotenv": "^16.4.5"
  }
}