    "build": "npx tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "ws": "^8.18.0"
  },
  "engines": { "node": ">=20.0.0" },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "typescript": "^5.9.2"
  }
}
