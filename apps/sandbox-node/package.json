{
  "name": "@monou/sandbox-node",
  "version": "0.1.0",
  "description": "Sandbox Node：以 role=node 连接 Gateway，在隔离 workspace 内执行 system.run / system.which（方案 B）",
  "type": "module",
  "main": "./dist/index.js",
  "bin": { "monou-sandbox-node": "./dist/index.js" },
  "scripts": {
