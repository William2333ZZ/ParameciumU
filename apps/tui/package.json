{
  "name": "@monou/tui-app",
  "version": "0.1.0",
  "description": "ParameciumU TUI — terminal client for Gateway chat and Cron (OpenClaw-style)",
  "type": "module",
  "main": "./dist/index.js",
  "bin": { "monou-tui": "./dist/index.js" },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npx tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@monou/gateway": "file:../../packages/gateway",
    "@monou/tui": "file:../../packages/tui",
    "chalk": "^5.3.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": { "node": ">=20.0.0" }
}
