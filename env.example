# 复制为 .env 并填入你的 key，不要提交 .env
# cp env.example .env
# AIHubMix（或其它 OpenAI 兼容 API，u-tui 优先使用）
AIHUBMIX_API_KEY=your_key_here
AIHUBMIX_BASE_URL=https://aihubmix.com/v1
# AIHUBMIX_MODEL=gpt-4o-mini  # 可选，默认 gpt-4o-mini

# 也可用 OpenAI 官方
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
